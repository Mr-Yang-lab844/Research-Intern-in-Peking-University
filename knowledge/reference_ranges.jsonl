{"id": "BASE_001", "test_name": "身高", "unit": "cm", "normal_range": "男性：165-185；女性：155-175", "source": "中国居民营养与慢性病状况报告", "description": "成年人身高范围，受遗传、营养等因素影响较大，无严格病理界限。", "low_status": "矮小症参考", "high_status": "正常高值"}
